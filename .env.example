# ═══════════════════════════════════════════════════════════════
# M.A.R.I.A. — Backend Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copia este archivo como .env.local y rellena los valores.
# NUNCA subas .env.local a git.
# ═══════════════════════════════════════════════════════════════

# ── INSFORGE ──────────────────────────────────────────────────
# URL de tu proyecto Insforge (cloud o self-hosted)
VITE_INSFORGE_URL=https://ex7k7mua.us-west.insforge.app
# Anon key pública — se expone al frontend, segura con RLS
VITE_INSFORGE_ANON_KEY=your-anon-key-here

# ── GOOGLE OAUTH ──────────────────────────────────────────────
# Obtén estos valores en: https://console.cloud.google.com
# APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redirect URI configurada en Google Cloud Console
# Para desarrollo: http://localhost:5173/auth/callback
# Para producción: https://tu-dominio.vercel.app/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# ── GOOGLE API SCOPES ─────────────────────────────────────────
# Scopes base para autenticación
GOOGLE_SCOPES=openid email profile

# Scopes específicos por servicio (se agregan al OAuth consent)
CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly
CLASSROOM_SCOPES=https://www.googleapis.com/auth/classroom.courses.readonly https://www.googleapis.com/auth/classroom.coursework.me.readonly https://www.googleapis.com/auth/classroom.announcements.readonly https://www.googleapis.com/auth/classroom.student-submissions.me.readonly

# ── GITHUB OAUTH ──────────────────────────────────────────────
# Obtén estos valores en: https://github.com/settings/developers
# Developer settings → OAuth Apps → New OAuth App
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── APP CONFIG ────────────────────────────────────────────────
# URL base de la aplicación
VITE_APP_URL=http://localhost:5173

# ── REDIS (Fase 4) ───────────────────────────────────────────
# Para cache de respuestas de Google APIs
# REDIS_URL=redis://default:password@host:port

# ═══════════════════════════════════════════════════════════════
# GUÍA DE CONFIGURACIÓN
# ═══════════════════════════════════════════════════════════════
#
# 1. GOOGLE CLOUD CONSOLE:
#    a) Ve a https://console.cloud.google.com
#    b) Crea/selecciona un proyecto
#    c) APIs & Services → Library → Habilita:
#       - Gmail API
#       - Google Calendar API
#       - Google Drive API
#       - Google Classroom API
#    d) APIs & Services → OAuth consent screen:
#       - Tipo: External
#       - Agrega los scopes listados arriba
#       - Agrega tu email como Test User
#    e) APIs & Services → Credentials → Create → OAuth 2.0 Client ID:
#       - Tipo: Web Application
#       - Authorized redirect URIs:
#         * http://localhost:5173/auth/callback (dev)
#         * https://tu-app.vercel.app/auth/callback (prod)
#         * https://<appkey>.insforge.app/auth/v1/callback (insforge)
#    f) Copia Client ID y Client Secret
#
# 2. GITHUB OAUTH:
#    a) Ve a https://github.com/settings/developers
#    b) OAuth Apps → New OAuth App
#    c) Authorization callback URL:
#       * http://localhost:5173/auth/callback (dev)
#       * https://tu-app.vercel.app/auth/callback (prod)
#    d) Copia Client ID y genera Client Secret
#
# 3. INSFORGE:
#    a) El anon key se obtiene del dashboard de Insforge
#    b) O ejecuta: npx @insforge/cli metadata
#
# 4. PARA REFRESH TOKENS OFFLINE (Google):
#    Al configurar el OAuth, asegúrate de enviar:
#    - access_type=offline
#    - prompt=consent
#    Esto genera un refresh_token que permite acceso
#    permanente sin que el usuario re-autorice.
# ═══════════════════════════════════════════════════════════════
